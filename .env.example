NODE_ENV=production
PORT=8000
APP_URL=https://your-domain.example
SESSION_SECRET=generate-a-long-random-secret

# Hosted model provider
OPENROUTER_API_KEY=replace-with-server-side-key

# Optional local model provider
OLLAMA_URL=http://127.0.0.1:11434

# Free OAuth provider: GitHub
OAUTH_PROVIDER=github
OAUTH_CLIENT_ID=replace-with-github-oauth-app-client-id
OAUTH_CLIENT_SECRET=replace-with-github-oauth-app-client-secret
OAUTH_REDIRECT_URI=https://your-domain.example/auth/callback
OAUTH_SCOPE=read:user user:email

# Optional: override endpoints for another OAuth/OIDC provider
# OAUTH_AUTH_URL=https://accounts.example.com/oauth2/v2/auth
# OAUTH_TOKEN_URL=https://accounts.example.com/oauth2/v2/token
# OAUTH_USERINFO_URL=https://accounts.example.com/oauth2/v2/userinfo

# Keep false in production. Development login is available only when NODE_ENV is not production.
DEV_AUTH_ENABLED=false
