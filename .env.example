NODE_ENV=production
PORT=8000
APP_URL=https://your-domain.example
SESSION_SECRET=generate-a-long-random-secret

# Hosted model provider
OPENROUTER_API_KEY=replace-with-server-side-key

# Optional local model provider
OLLAMA_URL=http://127.0.0.1:11434

# OAuth Redirect URI (shared by all providers)
OAUTH_REDIRECT_URI=https://your-domain.example/auth/callback

# Google OAuth (Free)
# https://console.developers.google.com/
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-oauth-client-secret

# Microsoft OAuth (Free)
# https://portal.azure.com/
MICROSOFT_OAUTH_CLIENT_ID=replace-with-microsoft-oauth-client-id
MICROSOFT_OAUTH_CLIENT_SECRET=replace-with-microsoft-oauth-client-secret

# GitHub OAuth (Free, optional)
# https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=replace-with-github-oauth-app-client-id
GITHUB_OAUTH_CLIENT_SECRET=replace-with-github-oauth-app-client-secret

# Legacy GitHub OAuth support (deprecated, use GITHUB_OAUTH_CLIENT_ID)
# OAUTH_CLIENT_ID=replace-with-github-oauth-app-client-id
# OAUTH_CLIENT_SECRET=replace-with-github-oauth-app-client-secret

# Keep false in production. Development login is available only when NODE_ENV is not production.
DEV_AUTH_ENABLED=false
